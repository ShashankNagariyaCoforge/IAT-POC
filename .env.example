# ================================================================
# IAT Insurance AI Email Automation Platform - Environment Variables
# Copy this file to .env and fill in real values before running.
# NEVER commit .env to source control.
# ================================================================

# ----- Azure Key Vault -----
AZURE_KEY_VAULT_URL=https://your-keyvault.vault.azure.net/

# ----- Azure Cosmos DB -----
AZURE_COSMOS_ENDPOINT=https://your-cosmos.documents.azure.com:443/
COSMOS_DATABASE_NAME=iatinsurance-db

# ----- Azure Blob Storage -----
AZURE_STORAGE_ACCOUNT_URL=https://your-storage.blob.core.windows.net
BLOB_CONTAINER_RAW_EMAILS=raw-emails
BLOB_CONTAINER_ATTACHMENTS=raw-attachments
BLOB_CONTAINER_EXTRACTED_TEXT=extracted-text

# ----- Azure OpenAI -----
AZURE_OPENAI_ENDPOINT=https://your-openai.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ----- Azure Document Intelligence (OCR - ACI Container) -----
DOC_INTELLIGENCE_ENDPOINT=http://your-aci-endpoint:5000

# ----- Microsoft Graph API (read from Key Vault at runtime) -----
# These are referenced by secret name in Key Vault, not set directly here.
GRAPH_CLIENT_ID=<client-id-from-key-vault-secret-name>
GRAPH_TENANT_ID=<tenant-id-from-key-vault-secret-name>
GRAPH_CERT_NAME=graph-api-certificate

# ----- Mailbox & Routing -----
TARGET_MAILBOX=claims@iatinsurance.com
DOWNSTREAM_EMAIL=processing@iatinsurance.com
WEBHOOK_URL=https://your-domain.com/webhook/email

# ----- Security -----
# 32-byte AES-256 key for PII mapping encryption (base64-encoded)
PII_ENCRYPTION_KEY=<base64-encoded-32-byte-key-from-key-vault>
# Secret for webhook signature verification
WEBHOOK_SECRET=<webhook-validation-secret>

# ----- Frontend (Vite build args) -----
VITE_AZURE_AD_CLIENT_ID=<ui-app-registration-client-id>
VITE_AZURE_AD_TENANT_ID=<azure-ad-tenant-id>
VITE_API_BASE_URL=https://your-domain.com

# ----- App Settings -----
ENVIRONMENT=development
LOG_LEVEL=INFO
WEBHOOK_SUBSCRIPTION_RENEWAL_HOURS=48
CLASSIFICATION_CONFIDENCE_THRESHOLD=0.75
CASES_PER_PAGE=50
